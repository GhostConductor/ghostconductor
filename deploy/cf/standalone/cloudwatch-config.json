{
  "agent": {
    "run_as_user": "root"
  },
  "logs": {
    "logs_collected": {
      "files": {
        "collect_list": [
          {
            "file_path": "/var/log/cloud-init-output.log",
            "log_group_name": "/ec2/ghostconductor/cloud-init",
            "log_stream_name": "{instance_id}"
          },
          {
            "file_path": "/var/log/ghostconductor.log",
            "log_group_name": "/ec2/ghostconductor/ghostconductor",
            "log_stream_name": "{instance_id}"
          }
        ]
      }
    }
  }
}
